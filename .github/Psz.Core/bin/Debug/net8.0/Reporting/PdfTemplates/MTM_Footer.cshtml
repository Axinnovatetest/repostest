@model Psz.Core.MaterialManagement.Reporting.Models.DocFooterModel

﻿<style>
     table td, table td * {
         vertical-align: top;
         text-align: left;
     }

         table td.right, table td.right * {
             text-align: left;
         }

     .hr {
         height: 1px;
         border-width: 0;
         color: black;
         background-color: black;
         width: 100%;
     }

     .footer-container {
         margin-left: 65px;
         font-size: 8px;
         width: 85%;
         border: 0px solid black;
         font-family: Helvetica, sans-serif;
         background-color:lightgray;
         border-top:1px solid black;
     }
</style>
@if (Model is not null)
{
    <div class="footer-container">
        <table style='width:100%;'>
            <tr>
                <td>
                    <table>
                        <tr><td>@Model.footerAddress1</td></tr>
                        <tr><td>@Model.footerAddress2</td></tr>
                        <tr><td>@Model.footerAddress3</td></tr>
                    </table>
                </td>
                <td>
                    <table style='border:0px solid red;width:100%;'>
                        <tr>
                            <td>
                                <table>
                                    <tr><td align='right' class="nobr right">@Model.footerLabelUst</td><td>@Model.footerValueUst</td></tr>
                                    <tr><td align='right' class="nobr right">@Model.footerLabelSite</td><td>@Model.footerValueSite</td></tr>
                                    <tr><td align='right' class="nobr right">@Model.footerLabelFax</td><td>@Model.footerValueFax</td></tr>
                                </table>
                            </td>
                            <td>
                                <table>
                                    <tr><td>@Model.footerLabelManager @Model.footerValueManager</td></tr>
                                    <tr><td>@Model.footerLabelManager2 @Model.footerValueManager2</td></tr>
                                    <tr><td>@Model.footerLabelTaxId @Model.footerValueTaxId</td></tr>
                                </table>
                            </td>
                            <td>
                                <table>
                                    <tr><td align='right'>@Model.footerLabelHRB</td><td>@Model.footerValueHRB</td></tr>
                                    <tr><td align='right'>@Model.footerLabelEmail</td><td>@Model.footerValueEmail</td></tr>
                                    <tr><td align='right'>@Model.footerLabelCustomsId</td><td>@Model.footerValueCustomsId</td></tr>
                                </table>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
            <tr>
                <td>
                    <table>
                        <!--Bankverbindung-->
                        <tr>
                            <td style='line-height:0.75rem;'>
                                @Model.footerBankLabel<br />
                                @Model.footerBankValue1<br />
                                @Model.footerBankValue2<br />
                                @Model.footerBankValue3<br />
                                @if (!string.IsNullOrEmpty(Model.footerBankValue4) && !string.IsNullOrWhiteSpace(Model.footerBankValue4))
                                {
                                    @Model.footerBankValue4<br />

                                }
                                @if (!string.IsNullOrEmpty(Model.Footer78) && !string.IsNullOrWhiteSpace(Model.Footer78))
                                {
                                    @Model.Footer78

                                    <br />

                                }
                            </td>
                        </tr>
                    </table>
                </td>
                <td>
                    <table style='border:0px solid red;width:100%;'>
                        <tr>
                            <td style='line-height:0.75rem;'>
                                @Model.footerAccountLabel<br />
                                @Model.footerAccountValue1<br />
                                @Model.footerAccountValue2<br />
                                @Model.footerAccountValue3<br />
                                @if (!string.IsNullOrEmpty(Model.footerAccountValue4) && !string.IsNullOrWhiteSpace(Model.footerAccountValue4))
                                {
                                    @Model.footerAccountValue4

                                    <br />

                                }
                                @if (!string.IsNullOrEmpty(Model.Footer79) && !string.IsNullOrWhiteSpace(Model.Footer79))
                                {
                                    @Model.Footer79

                                    <br />

                                }
                            </td>
                            <td style='line-height:0.75rem;'>
                                @Model.footerBLZLabel<br />
                                @Model.footerBLZValue1<br />
                                @Model.footerBLZValue2<br />
                                @Model.footerBLZValue3<br />
                                @if (!string.IsNullOrEmpty(Model.footerBLZValue4) && !string.IsNullOrWhiteSpace(Model.footerBLZValue4))
                                {
                                    @Model.footerBLZValue4

                                    <br />

                                }
                                @if (!string.IsNullOrEmpty(Model.Footer80) && !string.IsNullOrWhiteSpace(Model.Footer80))
                                {
                                    @Model.Footer80

                                    <br />

                                }
                            </td>
                            <td style='line-height:0.75rem;'>
                                @Model.footerIBANLabel<br />
                                @Model.footerIBANValue1<br />
                                @Model.footerIBANValue2<br />
                                @Model.footerIBANValue3<br />
                                @if (!string.IsNullOrEmpty(Model.footerIBANValue4) && !string.IsNullOrWhiteSpace(Model.footerIBANValue4))
                                {
                                    @Model.footerIBANValue4

                                    <br />

                                }
                                @if (!string.IsNullOrEmpty(Model.Footer81) && !string.IsNullOrWhiteSpace(Model.Footer81))
                                {
                                    @Model.Footer81

                                    <br />

                                }
                            </td>
                            <td style='line-height:0.75rem;'>
                                @Model.footerSWIFTLabel<br />
                                @Model.footerSWIFTValue1<br />
                                @Model.footerSWIFTValue2<br />
                                @Model.footerSWIFTValue3<br />
                                @if (!string.IsNullOrEmpty(Model.footerSWIFTValue4) && !string.IsNullOrWhiteSpace(Model.footerSWIFTValue4))
                                {
                                    @Model.footerSWIFTValue4

                                    <br />

                                }
                                @if (!string.IsNullOrEmpty(Model.Footer82) && !string.IsNullOrWhiteSpace(Model.Footer82))
                                {
                                    @Model.Footer82

                                    <br />

                                }
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
            @if (!string.IsNullOrEmpty(Model.Form) && !string.IsNullOrWhiteSpace(Model.Form))
            {
                <tr>
                    <td colspan="2"><br />@Model.Form</td>
                </tr>
            }

        </table>
    </div>
}