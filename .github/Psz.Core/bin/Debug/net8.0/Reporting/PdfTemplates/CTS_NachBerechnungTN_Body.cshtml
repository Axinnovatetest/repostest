@model Psz.Core.CustomerService.Reporting.Models.NachBerechnungTNReportModel
@using Psz.Core.CustomerService.Reporting.Helpers
<html>
<head>
    <style>
        @@page {
            margin-top: 20;
            margin-bottom: 150;
            margin-left: 20;
            margin-right: 50;
            font-family: Helvetica, sans-serif;
        }

        body {
            font-family: Helvetica, sans-serif;
        }

        table {
            border-collapse: collapse;
        }

        td, tr {
            padding: 10px 10px 0 0;
        }

        td {
            font-size: 10px !important;
        }
        .big{
            font-size: 14px !important;
        }
        .small{
            font-size: 8px !important;
        }
        .bold{
            font-weight: bold !important;
        }
        .medium
        {
            font-size: 10px !important;
        }
        .normal{
            font-weight: normal !important;
        }
        .hr {
            border: none;
            border-top: 2px solid black;
            padding: 5px;
        }

        .hr-dotted {
            border: none;
            border-top: 2px dotted black;
            padding: 5px;
        }
        .underline{
            text-decoration: underline !important;
        }
        .text-right{
            text-align: right !important;
        }

        .text-left {
            text-align: left !important;
        }

        .text-center {
            text-align: center !important;
        }
        .no-br{
            white-space:nowrap;
        }
    </style>
</head>
<body style="font-size:14px;">
    @if(Model is not null)
    {
      <table>
          <tr>
            <td class="normal small"></td>
          </tr>
            <tr>
                <td class="normal small"></td>
            </tr>
       </table>
            <table style="width:100%">
            <tr>
                <td class="big bold"></td>
                <td class="text-right">
                    <img style='height:50px;border:0px solid red;' src="@Model.Header.Logo">
                </td>
            </tr>
            </table>
        <hr class="hr">
      <table style="width:100%">
            <tr>
                <td class="normal underline text-left">PSZ Tunisie sarl - Zone industrielle Hadja Ali Soua - Ksar Hellal</td>
            </tr>
            <tr>
                <td class="medium bold text-left">PSZ electronic GmbH</td>
            </tr>
            <tr>
                <td class="medium bold text-left">Im Gstaudach 6</td>
            </tr>
            <tr>
                <td class="medium bold text-left">D-92648 Vohenstrauß</td>
            </tr>
            <tr>
                <td class="medium bold text-left">DE 813706578</td>
                <td class="bold big text-right">Facture actualisée</td>
            </tr>
      </table>
        <hr class="hr-dotted">
        <table style="width:100%">
            <tr>
                <td class="bold big text-left">Numéro de Facture: @Model.Header.Rechnungnummer</td>
                <td class="bold big text-right">Ksar Hellal/Tunisie le: @Model.Header.RechnungDatum</td>
            </tr>
            <tr>
                <td class="bold big">Période de Facturation de: @Model.Header.From             à: @Model.Header.To</td>
            </tr>
        </table>
        <table style="width:100%;margin-top:20px;">
            <tr>
                <th class="normal medium no-br">Numéro de ordre</th>
                <th class="normal medium no-br">Quantité</th>
                <th class="normal medium no-br">Référence produit</th>
                <th class="normal medium no-br">Designation</th>
                <th class="normal medium no-br">P.U. actualisé</th>
                <th class="normal medium no-br">Totale</th>
            </tr>
            <tr>
                <td style="border-bottom:1px solid black" colspan="7"></td>
            </tr>
            @foreach(var detail in Model.Details)
            {
                <tr>
                    <td class="normal medium text-center no-br">@detail.Fertigungsnummer</td>
                    <td class="normal medium text-center no-br">@detail.Anzahl</td>
                    <td class="normal medium text-center no-br">@detail.Artikelnummer</td>
                    <td class="normal medium text-center no-br">@detail.Bezfeld</td>
                    <td class="normal medium text-center">@FormatHelper.FormatDecimal(detail.Ausdr5, 3) €</td>
                    <td class="normal medium text-center no-br">@FormatHelper.FormatDecimal(detail.Ausdr3, 2) €</td>
                </tr>
            }
            <tr>
                <td colspan="7" style="border-bottom:1px solid black"></td>
            </tr>
            <tr>
                <td colspan="6" class="bold big text-center">Betrag in EURO</td>
                <td class="bold big text-right no-br">@(FormatHelper.FormatDecimal(Model.Details.Sum(x => x.Ausdr3), 2)) €</td>
            </tr>
        </table>
    }
</body>
<pre></pre>
</html>