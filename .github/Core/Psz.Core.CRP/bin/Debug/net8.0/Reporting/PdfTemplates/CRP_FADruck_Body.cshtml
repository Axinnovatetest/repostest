@model Psz.Core.CRP.Reporting.Models.FADruckModel

<html>
<head>
    <meta charset="UTF-8">
    <style>
        @@page {
            margin-top: 20;
            margin-bottom: 0;
            margin-left: 50;
            font-family: Helvetica, sans-serif;
        }

        body {
            font-family: Helvetica, sans-serif;
        }

        table {
            border-collapse: collapse;
        }

        table td, table td * {
            vertical-align: top;
            border-width: 0px;
        }

        .table-cell {
            color: black;
            padding: 5px 5px;
            text-align: left;
            font-size:10px;
        }
        .hr {
            height: 0.5px;
            border-width: 0;
            color: black;
            background-color: black;
        }

        .no-wrap
        {
            white-space: nowrap !important;
        }
        .left{
            text-align: left !important;
        }
        .center{
            text-align: center !important;
        }
        .left {
            text-align: left !important;
        }
        .right{
            text-align: right !important;
        }
        .big{
            font-size: 18px !important;
        }
        .medium{
            font-size: 14px !important;
        }

        .small {
            font-size: 10px !important;
        }
        .blue{
            color: #00006C;
        }
        .bold{
            font-weight: bold !important;
        }
        .normal{
            font-weight: normal !important;
        }
        .gray{
            background-color:gainsboro
        }
        .border-bottom{
            border-bottom: 1px solid black !important;
        }
        .max-80
        {
            max-width: 150px !important;
        }
        .vertival-top{
            vertical-align: top !important;
        }

        .vertival-middle {
            vertical-align: middle !important;
        }

        .blue-cell{
            background-color: dodgerblue;
            color: white;
            font-weight: bold;
            padding: 10px;
            font-size:10px;
        }
        .bordered{
            border: 1px solid black;
        }
        .bottom-dotted{
            border-bottom: 1px dotted black !important;
        }
        .rectangle{
            border: 1px solid black;
            width: 200px;
            height: 20px;
            margin:auto;
        }
        .square{
            border: 1px solid black;
            width: 20px;
            height: 20px;
        }
        .padding-10{
            padding:10px;
        }
    </style>
</head>
<body style="font-size:14px;">
    @if(Model !=null)
    {
        <table style="width:100%">
            <tr>
                <th class="left"><img src="data:image/png;base64,@Model.Header.FABarCode" style="width:150px" /></th>
                <th class="center big">@Model.Header.ErstmusterTag</th>
                <th class="left big blue normal right">PB: @Model.Header.Halle</th>
                <th class="left big blue normal right">P S Z <br /> @Model.Header.Company</th>
            </tr>
            <tr>
                <th colspan="4" class="blue center big normal">@Model.Header.Lagerort - @Model.Header.Fertigungsnummer</th>
            </tr>
        </table>
        <br />
        @if(Model.IsTechnick)
        {
            <table style="width:100%">
                <tr>
                    <th class="medium normal right gray border-bottom">Analyse zu D- @Model.Header.Fertigungsnummer</th>
                </tr>
            </table>
        }
        else
        {
        <table style="width:100%">
            <tr>
                <th class="medium normal right gray border-bottom">FA vom: @Model.Header.Datum</th>
                <th class="medium normal center gray border-bottom">Mandant: @Model.Header.Mandant</th>
                <th class="medium normal left gray border-bottom">In Lager: @Model.Header.Lagerort_id_zubuchen</th>
            </tr>
        </table>            
        }
        <br />
        <table style="width:100%">
            <tr>
                <th class="medium left">PSZ #: &nbsp;&nbsp;<span class="normal">@Model.Header.Artikelnummer</span></th>
                <th class="big right normal">Termin: &nbsp;&nbsp;@Model.Header.Termin_Bestätigt1</th>
            </tr>
            <tr>
                <th class="medium left">Bez. 1: &nbsp;&nbsp;<span class="normal">@Model.Header.Bezeichnung_1</span></th>
            </tr>
        </table>
        <br />
        <table style="width:100%">
            <tr>
                <th class="left medium">Artikelfamille: &nbsp;&nbsp; <span class="normal">@Model.Header.Artikelfamille</span></th>
                <th class="left medium">Detail 1: &nbsp;&nbsp; <span class="normal">@Model.Header.Detail_1</span></th>
                <th class="left medium">Detail 2: &nbsp;&nbsp; <span class="normal">@Model.Header.Detail_2</span></th>
            </tr>
            <tr>
                <th colspan="2" class="left medium">Index: &nbsp;&nbsp; <span class="normal">@Model.Header.Index_Kunde</span></th>
                <th colspan="2" class="bold medium right">min / Stk: @Model.Header.Produktionszeit </th>
            </tr>
            <tr>
                <th colspan="2" class="left medium">Menge: &nbsp;&nbsp; <span class="normal">@Model.Header.Anzahl</span></th>
                <th colspan ="2" class="bold medium right">h / FA : @Model.Header.H_FA  </th>
            </tr>
            <tr>
                <th style="vertical-align:top !important;" class="left medium">Bemerkung:</th>
                <th class="medium left normal max-80">
                    @Model.Header.Bemerkung
                </th>
                <th class="right"><img src="data:image/png;base64,@Model.Header.ESDLogo" style="width:50px" /></th>
                <th class="medium bold right">Status extern: @Model.Header.Freigabestatus <br /> Status intern: @Model.Header.Freigabestatus_TN_intern</th>
            </tr>
            <tr>
                <th colspan="3" class="left medium">Techniker: &nbsp;&nbsp; <span class="normal">@Model.Header.Techniker</span></th>
            </tr>
        </table>
        <br />
        <table style="width:100%">
            <tr>
                <th class="medium normal right gray">Material pro @Model.Header.Lagerort - @Model.Header.Fertigungsnummer</th>
                <th class="medium normal center gray">Verp.: @Model.Header.Verpackungsart</th>
                <th class="medium normal left gray">Verp.-Menge: @Model.Header.Verpackungsmenge</th>
                <th class="medium normal left gray">LG: @Model.Header.Losgroesse</th>
            </tr>
        </table>
        <table style="width:100%">
            <tr>
                <th class="blue-cell bordered center no-wrap">Artikelnummer</th>
                <th class="blue-cell bordered center no-wrap">Bedarf</th>
                <th class="blue-cell bordered center no-wrap">Bereit</th>
                <th class="blue-cell bordered center no-wrap">Bezeichnung 1</th>
                <th class="blue-cell bordered center no-wrap">Bezeichnung 2</th>
                <th class="blue-cell bordered center no-wrap">Lagerort</th>
                <th class="blue-cell bordered center">Scrap/Ausschuß</th>
            </tr>
            @foreach(var item in Model.Positions)
            {
                <tr>
                    <td class="bold small center bottom-dotted vertival-middle"><img src="data:image/png;base64,@item.img" style="width:30px" /> @item.Artikelnummer</td>
                    <td class="normal small center bottom-dotted vertival-middle">@item.Anzahl</td>
                    <td class="normal small center bottom-dotted vertival-middle"></td>
                    <td class="normal small center bottom-dotted vertival-middle">@item.Bezeichnung_1</td>
                    <td class="normal small center bottom-dotted vertival-middle">@item.Bezeichnung_2</td>
                    <td class="normal small center bottom-dotted vertival-middle">@item.Lagerort</td>
                    <td class="normal small center bottom-dotted vertival-middle"></td>
                </tr>
            }
        </table>
        @if(Model.Plannung!=null && Model.Plannung.Count()>0)
        {
            <div style="page-break-before: always;">
                <div class="gray bordered" style="width:100%;padding:10px;">
                    <table style="width:85%">
                        <tr>
                            <th class="normal medium left">P S Z Tunisie S.a.r.l</th>
                        </tr>
                        <tr>
                            <th class="normal medium left">Prubezna karta Rezama</th>
                            <th class="medium bold center">Plaunugssytem Laufkarte Schniederei:</th>
                        </tr>
                        <tr>
                            <th class="medium normal left">Laufkarte Schneiderei</th>
                            <th class="medium normal center"><div class="rectangle"></div></th>
                        </tr>
                    </table>
                </div>
                <table style="width:70%">
                    <tr>
                        <th class="bold medium left">FA #:</th>
                        <th class="medium normal right">@Model.Plannung[0].Fertigungsnummer</th>
                        <th class="medium bold right">FA Menge:</th>
                        <th class="medium normal left">@Model.Plannung[0].Anzahl</th>
                    </tr>
                    <tr>
                        <th class="bold medium left">PSZ #:</th>
                        <th class="medium normal right">@Model.Plannung[0].Artikelnummer</th>
                        <th class="medium bold right">FA Termin:</th>
                        <th class="medium normal left">@Model.Plannung[0].Termin_Bestätigt1</th>
                    </tr>
                </table>
                <tr><td colspan='9'><hr class='hr'></td></tr>
                <br />
                @foreach (var plan in Model.Plannung)
                {
                    <table style="width:100%">
                        <tr>
                            <th class="bold medium left vertival-top">@plan.Gewerk <br /><div class="square"></div></th>
                            <th class="right normal medium">
                                <table style="width:40%;margin-left:auto">
                                    <tr>
                                        <th class="blue-cell bordered center no-wrap">Datum</th>
                                        <th class="blue-cell bordered center no-wrap">Mar. Nr</th>
                                        <th class="blue-cell bordered center no-wrap">Platz Nr</th>
                                        <th class="blue-cell bordered center no-wrap">Anzahl Boxen </th>
                                    </tr>
                                    <tr>
                                        <td class="bordered padding-10"></td>
                                        <td class="bordered"></td>
                                        <td class="bordered"></td>
                                        <td class="bordered"></td>
                                    </tr>
                                    <tr>
                                        <td class="bordered padding-10"></td>
                                        <td class="bordered"></td>
                                        <td class="bordered"></td>
                                        <td class="bordered"></td>
                                    </tr>
                                    <tr>
                                        <td class="bordered padding-10"></td>
                                        <td class="bordered"></td>
                                        <td class="bordered"></td>
                                        <td class="bordered"></td>
                                    </tr>
                                </table>
                            </th>
                        </tr>
                    </table>
                }
            </div>
        }
        @if (Model.IsTechnick)
        {
            <div style="page-break-before: always;">
            <table style="width:100%">
                <tr>
                        <th class="small bold left gray">Stundenauswertung / Used Hours</th>
                </tr>
            </table>
            <table style="width:100%">
                <tr>
                        <th class="blue-cell normal small center bordered">Datum/Date</th>
                        <th class="blue-cell normal small center bordered">
                            Techniker /<br />
                            Technician
                        </th>
                        <th class="blue-cell normal small center bordered">
                            Dukumentation /<br />
                            Ducumentation
                        </th>
                        <th class="blue-cell normal small center bordered">
                            Musterbau /<br />
                            Sample Build
                        </th>
                        <th class="blue-cell normal small center bordered">
                            AutoCAD/E /<br />
                            Konstruction
                        </th>
                        <th class="blue-cell normal small center bordered">
                            Montage,Testbretter /<br />
                            Assembly,-Testboards
                        </th>
                        <th class="blue-cell normal small center bordered">
                            Bemerkung / Comment
                        </th>
                </tr>
                    @for (int i = 1; i <= 10; i++)
                    {
                        <tr>
                            <td class="padding-10 bordered"></td>
                            <td class="padding-10 bordered"></td>
                            <td class="padding-10 bordered"></td>
                            <td class="padding-10 bordered"></td>
                            <td class="padding-10 bordered"></td>
                            <td class="padding-10 bordered"></td>
                            <td class="padding-10 bordered"></td>
                        </tr>
                    }
            </table>
            <br />
                <table style="width:100%">
                    <tr>
                        <th class="small bold left gray">Materialbedarf / Needed Material</th>
                    </tr>
                </table>
                <table style="width:100%">
                    <tr>
                        <th class="blue-cell normal small center bordered">PSZ#</th>
                        <th class="blue-cell normal small center bordered">
                            Menge /<br />
                            Quantity
                        </th>
                        <th class="blue-cell normal small left bordered">
                            Bemerkung / Comment
                        </th>
                    </tr>
                    @for (int i = 1; i <= 10; i++)
                    {
                        <tr>
                            <td class="padding-10 bordered"></td>
                            <td class="padding-10 bordered"></td>
                            <td class="padding-10 bordered"></td>
                        </tr>
                    }
                </table>
            </div>
        }
    }
    <pre></pre>
</body>
</html>