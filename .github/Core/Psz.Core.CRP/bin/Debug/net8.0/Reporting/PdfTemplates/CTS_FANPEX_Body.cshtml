@model Psz.Core.CustomerService.Reporting.Models.FA_NPEX_ReportModel
@using Psz.Core.CustomerService.Reporting.Helpers
<html>
<head meta charset="utf-8">
    <style>
        @@page {
            margin-top: 20;
            margin-bottom: 100;
            margin-left: 50;
            margin-right: 50;
            font-family: Helvetica, sans-serif;
        }

        body {
            font-family: Helvetica, sans-serif;
        }

        table {
            border-collapse: collapse;
        }

        table td, table td * {
            vertical-align: top;
            border-width: 0px;
        }
        .small-text{
            font-size:10px;
        }
        .big-text{
            font-size:18px;
        }
        .float-left{
            float:left;
        }

        .float-right{
            float: right;
        }
        .undeline{
            text-decoration: underline;
        }
        .bold{
            font-weight: bold !important;
        }
        .normal
        {
            font-weight: normal !important;
        }
        .transparent{
            color: transparent;
        }
        .no-br{
            white-space: nowrap;
        }
        .square
        {
            width: 12px;
            height: 12px;
            border: 1px solid black;
        }
        .border-dotted{
            border-bottom: 1px dotted black;
        }
        .padding-top-bottom{
            padding-top: 6px;
            padding-bottom: 6px;
        }

        .hr {
            height: 1px;
            border-width: 0;
            color: navy;
            background-color: navy;
        }
        .center-text{
            text-align: center;
        }
        .left-text{
            text-align: left;
        }
    </style>
</head>
<body style="font-size:14px;">
    <table style="width:100%">
        <tr>
            <th class="small-text float-left">Zerti fiziert nach <br /> DIN EN ISO 9001 :2000</th>
            <th class="big-text float-right undeline">Open Orders Status: N / P / E / X</th>
        </tr>
    </table>
    @if(Model is not null)
    {
        foreach(var kunde in Model.Kunden)
        {
          <table style="width:40%;margin-top:50px">
              <tr>
                    <th class="big-text normal float-left">Customer :</th>
                    <th class="big-text bold float-left">@kunde.Kunde</th>
              </tr>
          </table>
            var articles = Model.Articles.Where(a => a.Kunde == kunde.Kunde).ToList();
            @foreach(var article in articles)
            {
                <table style="width:80%;margin-top:40px">
                    <tr>
                        <th class="normal small-text">PSZ Part# :</th>
                        <th class="bold small-text">@article.Artikelnummer</th>
                        <th class="normal small-text">Cust.Part# :</th>
                        <th class="bold small-text">@article.Bezeichnung_1</th>
                        <th class="normal small-text">Status ext:</th>
                        <th class="bold small-text">@article.Freigabestatus</th>
                    </tr>
                </table>
                var orders = Model.Orders.Where(o => o.Artikelnummer == article.Artikelnummer && o.Kunde == kunde.Kunde).ToList();
                @foreach(var order in orders)
                {
                    <table style="width:100%;margin-top:10px">
                        <tr>
                            <td class="normal small-text no-br">Order# :</td>
                            <td class="normal small-text no-br">@order.Fertigungsnummer</td>
                            <td class="transparent">xxxxxxx</td>
                            <td class="normal small-text no-br">Qty.:</td>
                            <td class="bold small-text no-br">@order.Anzahl</td>
                            <td class="transparent">xxxxxxx</td>
                            <td class="normal small-text no-br">Due Date:</td>
                            <td class="bold small-text">@order.Termin_Fertigstellung</td>
                            <td class="transparent">xxxxxxx</td>
                            <td class="normal small-text no-br">Eng. Date:</td>
                            <td class="bold small-text">@order.Termin_Bestätigt1</td>
                            <td class="transparent no-br">xxxxxxx</td>
                            <td class="normal small-text">@order.Bemerkung</td>
                        </tr>
                    </table>
                    <table style="width:30%">
                        <tr>
                            <th class="small-text normal float-left">Erstmunsterauftrag:</th>
                            <th class="float-left"><div class="square">@(order.Erstmuster?"X":"")</div></th>
                            <th class="small-text bold float-left">@order.Preis</th>
                        </tr>
                    </table>
                    var details = Model.Details.Where(od => od.Fertigungsnummer == order.Fertigungsnummer).ToList();
                    <table style="width:100%;margin-top:20px">
                        <tr>
                            <th class="small-text bold border-dotted no-br left-text">Material Problems</th>
                            <th class="small-text normal border-dotted no-br center-text">Raw Material #</th>
                            <th class="small-text normal border-dotted no-br center-text">Raw Mat. Descr.</th>
                            <th class="small-text normal border-dotted no-br center-text">Qty./Peice</th>
                            <th class="small-text normal border-dotted no-br center-text">Nedded Qty.</th>
                            <th class="small-text normal border-dotted no-br center-text">Exsisting Qty.</th>
                        </tr>
                        @foreach (var detail in details)
                        {
                            <tr>
                                <td class="small-text bold padding-top-bottom"></td>
                                <td class="small-text normal padding-top-bottom center-text">@detail.Stucklisten_Artikelnummer</td>
                                <td class="small-text normal padding-top-bottom center-text" style="max-width:120px">@detail.Bezeichnung_des_Bauteils</td>
                                <td class="small-text normal padding-top-bottom center-text">@detail.Stucklisten_Anzahl</td>
                                <td class="small-text normal padding-top-bottom center-text">@detail.Bedarf</td>
                                <td class="small-text normal padding-top-bottom center-text">@detail.Bestand</td>
                            </tr>
                        }
                    </table>
                    <hr class='hr'>
                }
            }
        }
    }
    <pre></pre>
</body>
</html>