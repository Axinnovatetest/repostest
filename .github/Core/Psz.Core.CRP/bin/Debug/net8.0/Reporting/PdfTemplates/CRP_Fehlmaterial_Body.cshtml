@model IEnumerable<Psz.Core.CRP.Reporting.Models.AnalyseSchneiderei1Model>
@{
    var _list = Model.ToList();
}
<html>
<head>
    <meta charset="UTF-8">
    <style>
        @@page {
            margin-top: 70;
            margin-bottom: 50;
            margin-left: 50;
            font-family: Helvetica, sans-serif;
        }

        body {
            font-family: Helvetica, sans-serif;
        }

        table {
            border-collapse: collapse;
        }

        table td, table td * {
            vertical-align: top;
            border-width: 0px;
        }

        .table-cell {
            color: black;
            padding: 5px 5px;
            text-align: left;
            font-size:10px;
        }
        .no-wrap
        {
            white-space: nowrap;
        }
        .max-100{
            max-width:100px;
        }
        .blue-label
        {
            color: blue;
            font-weight: bold;
            font-size: 11px;
            width:100%;
            text-align: center;
        }
        .bold{
            font-weight: bold;
        }
        .medium
        {
            font-size:10px;
        }

        .hr {
            height: 0.5px;
            border-width: 0;
            color: black;
            background-color: black;
        }
        .bold{
            font-weight: bold;
        }
        .normal
        {
            font-weight: normal;
        }
    </style>
</head>
<body style="font-size:14px;">
    <h3 class="blue-label">Fehlermaterialanalyse für FA #  @(_list!=null && _list.Count>0?_list[0].Fer:0)</h3>
    <tr><td colspan='9'><hr class='hr'></td></tr>
    @if(Model !=null && Model.Count() > 0)
    {
        <table style="width:100%">
            <tr>
                <th class="table-cell bold no-wrap">Wunschtermin</th>
                <th class="table-cell bold no-wrap">Prod. -termin</th>
                <th class="table-cell bold no-wrap">FA#</th>
                <th class="table-cell bold no-wrap">Menge</th>
                <th class="table-cell bold no-wrap">PSZ#</th>
                <th class="table-cell bold no-wrap">Kunden#</th>
                <th class="table-cell bold no-wrap">Umsatz Produktion</th>
                <th class="table-cell bold no-wrap">Prod.Zeit h</th>
            </tr>
            <tr>
                <td class="table-cell normal no-wrap">@_list[0].T_F</td>
                <td class="table-cell normal no-wrap">@_list[0].T_B1</td>
                <td class="table-cell normal no-wrap">@_list[0].Fer</td>
                <td class="table-cell normal no-wrap">@_list[0].Anz</td>
                <td class="table-cell normal no-wrap">@_list[0].Artik_Nr</td>
                <td class="table-cell normal no-wrap">@_list[0].B1</td>
                <td class="table-cell normal no-wrap">@_list[0].UmCZ</td>
                <td class="table-cell normal no-wrap">@_list[0].Prod</td>
            </tr>
        </table>
        <br />
        <table style="width:100%">
            <tr>
                <th class="table-cell bold no-wrap">Material#PSZ</th>
                <th class="table-cell bold no-wrap">Bezeichung</th>
                <th class="table-cell bold no-wrap">Bedarf gesamt</th>
                <th class="table-cell bold no-wrap">Bestand</th>
                <th class="table-cell bold no-wrap">Verfügbar</th>
            </tr>
                @foreach(var item in Model)
                {
            <tr>
                    <td class="table-cell normal no-wrap">@item.Artik_Nr2</td>
                    <td class="table-cell normal max-100">@item.BZ2</td>
                    <td class="table-cell normal no-wrap">@item.SummFAB</td>
                    <td class="table-cell normal no-wrap">@item.SummBe</td>
                    <td class="table-cell normal no-wrap">@item.Ver</td>
            </tr>
                }
        </table>
    }
    <pre></pre>
</body>
</html>