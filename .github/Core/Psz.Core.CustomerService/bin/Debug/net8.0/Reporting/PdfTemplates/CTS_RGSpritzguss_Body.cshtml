@model Psz.Core.CustomerService.Reporting.Models.RechnungModel
@using Psz.Core.CustomerService.Reporting.Helpers
<html>
<head>
    <style>
        @@page {
            margin-top: 20;
            margin-bottom: 150;
            margin-left: 20;
            margin-right: 50;
            font-family: Helvetica, sans-serif;
        }

        body {
            font-family: Helvetica, sans-serif;
        }

        table {
            border-collapse: collapse;
        }

        td, tr {
            padding: 10px 10px 0 0;
        }

        td {
            font-size: 10px !important;
        }
        .big{
            font-size: 14px !important;
        }
        .small{
            font-size: 8px !important;
        }
        .bold{
            font-weight: bold !important;
        }
        .medium
        {
            font-size: 10px !important;
        }
        .normal{
            font-weight: normal !important;
        }
        .hr {
            border: none;
            border-top: 2px solid black;
            padding: 5px;
        }

        .hr-dotted {
            border: none;
            border-top: 2px dotted black;
            padding: 5px;
        }
        .underline{
            text-decoration: underline !important;
        }
        .text-right{
            text-align: right !important;
        }

        .text-left {
            text-align: left !important;
        }

        .text-center {
            text-align: center !important;
        }
        .break
        {
            max-width: 20px;
            white-space: nowrap;
            word-break: break-all;
            text-align: center;
        }
        .new-page {
            page-break-before: always;
            break-before: column;
        }
    </style>
</head>
<body style="font-size:14px;">
    @if(Model is not null)
    {
      <table>
          <tr>
            <td class="normal small">Zertifiziert nach</td>
          </tr>
            <tr>
                <td class="normal small">DIN EN ISO 9001:2008</td>
            </tr>
            <tr>
                <td class="big bold">@Model.ReportParameters.SumTitle4</td>
                <td>
                    <div style="width:100%;text-align:right;">
                        <img style='height:50px;border:0px solid red;' src="@Model.ReportParameters.Logo">
                    </div>
                </td>
            </tr>
      </table>
        <hr class="hr">
      <table>
          <tr>
                <td class="medium normal">@Model.ReportParameters.Header1</td>
          </tr>
            <tr>
                <td class="medium bold">@Model.ReportParameters.Header2</td>
            </tr>
            <tr>
                <td class="medium bold">@Model.ReportParameters.Header3</td>
            </tr>
            <tr>
                <td class="medium bold">@Model.ReportParameters.Header4</td>
            </tr>
            <tr>
                <td class="medium bold">@Model.ReportParameters.Header5</td>
            </tr>
      </table>
        <hr class="hr-dotted">
        <table style="width:100%">
            <tr>
                <td class="bold">@Model.ReportParameters.Title1 @Model.ReportParameters.RechnungNummer</td>
                <td class="bold text-right">@Model.ReportParameters.Title2 @Model.ReportParameters.RechnungDatum</td>
            </tr>
            <tr>
                <td class="normal underline">@Model.ReportParameters.Title3</td>
                <td class="bold text-right"> @Model.ReportParameters.Title4 @Model.ReportParameters.From <br />@Model.ReportParameters.Title5 @Model.ReportParameters.To </td>
            </tr>
            <tr>
                <td class="normal">@Model.ReportParameters.Title6</td>
            </tr>
            <tr>
                <td class="normal">@Model.ReportParameters.Title7 @Model.ReportParameters.LimitDate</td>
            </tr>
        </table>
        <table style="width:100%">
            <tr>
                <th class="normal medium">@Model.ReportParameters.List1Column1</th>
                <th class="normal medium">@Model.ReportParameters.List1Column2</th>
                <th class="normal medium">@Model.ReportParameters.List1Column3.Split("\r\n")[0] <br />@Model.ReportParameters.List1Column3.Split("\r\n")[1]</th>
                <th class="normal medium">@Model.ReportParameters.List1Column4.Split("\r\n")[0] <br />@Model.ReportParameters.List1Column4.Split("\r\n")[1]</th>
                <th class="normal medium">@Model.ReportParameters.List1Column5</th>
                <th class="normal medium">@Model.ReportParameters.List1Column6 <br /> @Model.ReportParameters.List1Column7</th>
                <th class="bold medium">@Model.ReportParameters.List1Column8 <br /> @Model.ReportParameters.List1Column9 <br /> @Model.ReportParameters.List1Column10</th>
            </tr>
            <tr>
                <td style="border-bottom:1px solid black" colspan="7"></td>
            </tr>
            @foreach(var detail in Model.Details)
            {
                <tr>
                    <td class="normal medium text-center">@detail.Datum</td>
                    <td class="normal medium text-center">@detail.Fertigungsnummer</td>
                    <td class="normal medium text-center">@detail.Anzahl <br /> @(detail.Gesamtgewicht/1000)</td>
                    <td class="normal medium text-center">@detail.Artikelnummer <br /> @detail.Zolltarif_nr</td>
                    <td class="normal medium text-center">@detail.Bezfeld</td>
                    <td class="normal medium text-center">@FormatHelper.FormatDecimal(detail.Preis, 2) € <br /> @FormatHelper.FormatDecimal(detail.Material1,2) €</td>
                    <td class="bold medium text-center">@FormatHelper.FormatDecimal(detail.Ausdr3,2) €</td>
                </tr>
            }
            <tr>
                <td colspan="7" style="border-bottom:1px solid black"></td>
            </tr>
            <tr>
                <td colspan="6" class="bold big text-center">@Model.ReportParameters.SumTitle1</td>
                <td class="bold big text-right">@(FormatHelper.FormatDecimal(Model.Details.Sum(x => x.Ausdr3),2)) €</td>
            </tr>
        </table>
        <div class="new-page">
            <table style="width:100%;margin:20px">
                <tr>
                    <th class="bold big text-left">@Model.ReportParameters.SumTitle2 @Model.ReportParameters.RechnungNummer vom @Model.ReportParameters.RechnungDatum</th>
                </tr>
                <tr>
                    <th class="bold big text-left">@Model.ReportParameters.SumTitle3 @Model.ReportParameters.From bis @Model.ReportParameters.To</th>
                </tr>
            </table>
            <table style="width:100%">
                <tr><td colspan="6" style="border-bottom:1px solid black"></td></tr>
                <tr>
                    <th class="medium bold">@Model.ReportParameters.List2Column1</th>
                    <th class="medium bold">@Model.ReportParameters.List2Column2</th>
                    <th class="medium bold">@Model.ReportParameters.List2Column3</th>
                    <th class="medium bold">@Model.ReportParameters.List2Column4</th>
                    <th class="medium bold">@Model.ReportParameters.List2Column6</th>
                    <th class="medium bold">@Model.ReportParameters.List2Column7</th>
                </tr>
                <tr><td colspan="6" style="border-bottom:1px solid black"></td></tr>
                @foreach (var zoll in Model.Zollatarif)
                {
                    <tr>
                        <td class="medium bold text-center">Nr.: @zoll.Zolltarif_nummer</td>
                        <td class="medium bold text-center">@FormatHelper.FormatDecimal(zoll.Gewicht, 2)</td>
                        <td class="medium bold text-center">@zoll.Positionen</td>
                        <td class="medium bold text-center">@FormatHelper.FormatDecimal(zoll.Lohnleistun, 2) €</td>
                        <td class="medium bold text-center">@FormatHelper.FormatDecimal(zoll.Material, 2) €</td>
                        <td class="medium bold text-center">@FormatHelper.FormatDecimal(zoll.Stat_Wert, 2) €</td>
                    </tr>
                }
                <tr><td colspan="6" style="border-bottom:1px solid black"></td></tr>
                <tr><td colspan="6" style="border-bottom:1px solid black"></td></tr>
            </table>
            <table style="width:100%">
                <tr>
                    <td class="bold medium text-right">Summen</td>
                    <td class="bold medium text-right">@(FormatHelper.FormatDecimal(Model.Zollatarif.Sum(z => z.Gewicht), 2))</td>
                    <td class="bold medium text-right">@(FormatHelper.FormatDecimal(Model.Zollatarif.Sum(z => z.Positionen), 2))</td>
                    <td class="bold medium text-right">@(FormatHelper.FormatDecimal(Model.Zollatarif.Sum(z => z.Lohnleistun), 2)) €</td>
                    <td class="bold medium text-right">@(FormatHelper.FormatDecimal(Model.Zollatarif.Sum(z => z.Material), 2)) €</td>
                    <td class="bold medium text-right">@(FormatHelper.FormatDecimal(Model.Zollatarif.Sum(z => z.Stat_Wert), 2)) €</td>
                </tr>
            </table>
        </div>
    }
</body>
<pre></pre>
</html>