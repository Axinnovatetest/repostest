@model Psz.Core.CRP.Reporting.Models.FAWunshUpdateReporUsertModel

<html>
<head>
    <meta charset="UTF-8">
    <style>
        @@page {
            margin-top: 20;
            margin-bottom: 0;
            margin-left: 50;
            font-family: Helvetica, sans-serif;
        }

        body {
            font-family: Helvetica, sans-serif;
        }

        table {
            border-collapse: collapse;
        }

        table td, table td * {
            vertical-align: top;
            border-width: 0px;
        }

        .table-cell {
            color: black;
            padding: 5px 5px;
            text-align: left;
            font-size:10px;
        }
        .hr {
            height: 0.5px;
            border-width: 0;
            color: black;
            background-color: black;
        }

        .no-wrap
        {
            white-space: nowrap !important;
        }
        .left{
            text-align: left !important;
        }
        .center{
            text-align: center !important;
        }
        .left {
            text-align: left !important;
        }
        .right{
            text-align: right !important;
        }
        .big{
            font-size: 18px !important;
        }
        .medium{
            font-size: 14px !important;
        }

        .small {
            font-size: 10px !important;
        }
        .blue{
            color: #00006C;
        }
        .bold{
            font-weight: bold !important;
        }
        .normal{
            font-weight: normal !important;
        }
        .gray{
            background-color:gainsboro
        }
        .border-bottom{
            border-bottom: 1px solid black !important;
        }
        .max-80
        {
            max-width: 150px !important;
        }
        .vertival-top{
            vertical-align: top !important;
        }

        .vertival-middle {
            vertical-align: middle !important;
        }

        .blue-cell{
            background-color: dodgerblue;
            color: white;
            font-weight: bold;
            padding: 10px;
            font-size:10px;
        }
        .bordered{
            border: 1px solid black;
        }
        .bottom-dotted{
            border-bottom: 1px dotted black !important;
        }
        .rectangle{
            border: 1px solid black;
            width: 200px;
            height: 20px;
            margin:auto;
        }
        .square{
            border: 1px solid black;
            width: 20px;
            height: 20px;
        }
        .padding-10{
            padding:10px;
        }
        .underline{
            text-decoration: underline !important;
        }
        .green{
            color: green !important;
        }
        .red {
            color: red !important;
        }
    </style>
</head>
<body style="font-size:14px;">
    <table style="width:100%">
        <tr>
            <th class="left"><img src="@Model.Logo" style="width:150px" /></th>
        </tr>
        <tr>
            <th class="gray left small bold">PSZ Electronic GmbH - Zum Beckenkeller 4 - 92648 Vohen strauß</th>
        </tr>
        <tr>
            <th class="bold small left">Erstellt  @(DateTime.Now)</th>
        </tr>
    </table>
    <br />
    <br />
    <table style="width:100%">
        <tr>
            <th class="green medium bold left">FA-Termin aktualisert</th>
        </tr>
    </table>
    <table style="width:100%">
        <tr>
            <th class="center small normal">Fertigunsnummer</th>
            <th class="center small normal">Artikelnummer</th>
            <th class="center small normal">Produktionstermin</th>
        </tr>
        <tr>
            <th colspan="3" style="border-bottom:1px solid black"></th>
        </tr>
        @if (Model.Updated != null && Model.Updated.Count() > 0)
        {
            foreach (var item in Model.Updated)
            {
                <tr>
                    <td class="small normal center normal">@item.Fertigungsnummer</td>
                    <td class="small normal center normal">@item.Artikelnummer</td>
                    <td class="small normal center normal">@item.Werk_termin</td>
                </tr>
            }
        }
    </table>
    <br />
    <br />
    <table style="width:100%">
        <tr>
            <th class="red medium bold left">FA-Termin fehlgeschlagen</th>
        </tr>
    </table>
    <table style="width:100%">
        <tr>
            <th class="center small normal">Fertigunsnummer</th>
            <th class="center small normal">Artikelnummer</th>
            <th class="center small normal">Produktionstermin</th>
            <th class="center small normal">Gedruckt</th>
            <th class="center small normal">Begonnen</th>
            <th class="center small normal">Geschnitten</th>
            <th class="center small normal">Termin <br />Error</th>
            <th class="center small normal">Gestarte</th>
            <th class="center small normal">FA Status</th>
        </tr>
        <tr>
            <th colspan="9" style="border-bottom:1px solid black"></th>
        </tr>
        @if (Model.NotUpdated != null && Model.NotUpdated.Count() > 0)
        {
            foreach (var item in Model.NotUpdated)
            {
                <tr>
                    <td class="small normal center">@item.Fertigungsnummer</td>
                    <td class="small normal center">@item.Artikelnummer</td>
                    <td class="small normal center">@item.ProduKtionstermin</td>
                    <td class="small normal center">@item.Gedruckt</td>
                    <td class="small normal center">@item.Begonnen</td>
                    <td class="small normal center">@item.Geschnitten</td>
                    <td class="small normal center">@item.Termin_error</td>
                    <td class="small normal center">@item.Gestartet</td>
                    <td class="small normal center">@item.NotOpen</td>
                </tr>
            }
        }
    </table>
    <pre></pre>
</body>
</html>