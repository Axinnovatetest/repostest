@model Psz.Core.CustomerService.Reporting.Models.DeliveryNotesCompilationFooterModel
<style>
    table td, table td * {
        vertical-align: top;
        text-align: left;
    }
	table td.right, table td.right * {
        text-align: left;
    }

    .hr {
        height: 1px;
        border-width: 0;
        color: black;
        background-color: black;
        width: 100%;
    }
</style>
<div style="margin-left:65px;font-size:8px;width:85%;border:0px solid black;font-family: Helvetica, sans-serif;<!-- margin-left:70px;padding-right:70px;text-align: center;background-color:lightgray-->">
    <table style='width:100%;'>
        <tr><td colspan='2'><hr class='hr' /></td></tr>
        <tr>
            <td>
                <table>
                    <tr><td>@Model.FooterAddress1</td></tr>
                    <tr><td>@Model.FooterAddress2</td></tr>
                    <tr><td>@Model.FooterAddress3</td></tr>
                </table>
            </td>
            <td>
                <table style='border:0px solid red;width:100%;'>
                    <tr>
						<td>
							<table>
								<tr><td align='right' class="nobr right">@Model.FooterLabelUst</td><td>@Model.FooterValueUst</td></tr>
								<tr><td align='right' class="nobr right">@Model.FooterLabelSite</td><td>@Model.FooterValueSite</td></tr>
								<tr><td align='right' class="nobr right">@Model.FooterLabelFax</td><td>@Model.FooterValueFax</td></tr>
							</table>
						</td>
						<td>
							<table>
								<tr><td>@Model.FooterLabelManager @Model.FooterValueManager</td></tr>
								<tr><td>@Model.FooterLabelManager2 @Model.FooterValueManager2</td></tr>
								<tr><td>@Model.FooterLabelTaxId @Model.FooterValueTaxId</td></tr>
							</table>
						</td>
						<td>
							<table>
								<tr><td align='right'>@Model.FooterLabelHRB</td><td>@Model.FooterValueHRB</td></tr>
								<tr><td align='right'>@Model.FooterLabelEmail</td><td>@Model.FooterValueEmail</td></tr>
								<tr><td align='right'>@Model.FooterLabelCustomsId</td><td>@Model.FooterValueCustomsId</td></tr>
							</table>
						</td>
					</tr>
                </table>
			</td>
        </tr>
        <tr>
			<td>
				<table>
					<!--Bankverbindung-->
					<tr>
						<td style='line-height:0.75rem;'>
							@Model.FooterBankLabel<br />
							@Model.FooterBankValue1<br />
							@Model.FooterBankValue2<br />
							@Model.FooterBankValue3<br />
							@Model.FooterBankValue4
						</td>
					</tr>
				</table>
			</td>
			<td>
				<table style='border:0px solid red;width:100%;'>
					<tr>
						<td style='line-height:0.75rem;'>
							@Model.FooterAccountLabel<br />
							@Model.FooterAccountValue1<br />
							@Model.FooterAccountValue2<br />
							@Model.FooterAccountValue3<br />
							@Model.FooterAccountValue4
						</td>
						<td style='line-height:0.75rem;'>
							@Model.FooterBLZLabel<br />
							@Model.FooterBLZValue1<br />
							@Model.FooterBLZValue2<br />
							@Model.FooterBLZValue3<br />
							@Model.FooterBLZValue4
						</td>
						<td style='line-height:0.75rem;'>
							@Model.FooterIBANLabel<br />
							@Model.FooterIBANValue1<br />
							@Model.FooterIBANValue2<br />
							@Model.FooterIBANValue3<br />
							@Model.FooterIBANValue4
						</td>
						<td style='line-height:0.75rem;'>
							@Model.FooterSWIFTLabel<br />
							@Model.FooterSWIFTValue1<br />
							@Model.FooterSWIFTValue2<br />
							@Model.FooterSWIFTValue3<br />
							@Model.FooterSWIFTValue4
						</td>
					</tr>
				</table>
			</td>
        </tr>
        
        <tr>
            <td colspan="2"><br />PSZ Form# F-072-01</td>
        </tr>
    </table>
</div>

