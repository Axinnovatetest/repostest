@model Psz.Core.CustomerService.Reporting.Models.CSContactFAReportModel
@using Psz.Core.CustomerService.Reporting.Helpers
<html>
<head meta charset="utf-8">
    <style>
	   @@page {
            margin-top: 70;
            margin-bottom: 180;
            margin-left: 50;
            margin-right: 50;
            font-family: Helvetica, sans-serif;
        }

        body {
            font-family: Helvetica, sans-serif;
        }

        table {
            border-collapse: collapse;
        }

        table td, table td * {
                vertical-align: top;
                border-width: 0px;
         }
        .red-text{
            font-weight: bold;
            color: red;
            font-size:12px;
        }
        .black-text
        {
            font-weight: bold;
            color: black;
            font-size: 12px;
            text-align: left;
        }

        .navy-text {
            font-weight: bold;
            color: navy;
            font-size: 12px;
            text-align: left;
        }

        .orange-header {
            padding: 5px;
            background-color: orange;
            font-size: 12px;
            color: green;
            width: 40%;
            font-weight:bold;
        }
        .yellow-cell
        {
            background-color: yellow;
            text-align:right;
        }

        .green-cell {
            background-color: #32CD32;
            text-align: right;
        }
        .blue-cell {
            background-color: aqua;
            text-align: right;
        }

        .hr {
            height: 1px;
            border-width: 0;
            color: navy;
            background-color: navy;
        }
	</style>
</head>
<body style="font-size:14px;">
	<p class="red-text">Stoniert FA# werden nicht baücksichtgt </p>
    @if(Model is not null)
    {
        <table style="width:50%">
            <tr>
                <th class="navy-text">FA#  von :</th>
                <th class="black-text">@Model.Header.DateFrom</th>
                <th class="navy-text">Bis</th>
                <th class="black-text">@Model.Header.DateTo</th>
            </tr>
        </table>
        foreach(var item in Model.Details)
        {
            <p class="orange-header">@item.Contact</p>
            <hr class='hr'>
            <table style="width:40%">
                <tr>
                    <th class="navy-text">Gesamt FA#. :</th>
                    <th class="black-text yellow-cell">@FormatHelper.FormatDecimal(item.FACount,1)</th>
                </tr>
                <tr>
                    <th class="navy-text">Anteil FA#. in %:</th>
                    <th class="black-text green-cell">@FormatHelper.FormatDecimal(item.Percentage,2) %</th>
                </tr>
                <tr>
                    <td colspan="2"><hr class='hr'></td>
                </tr>
            </table>    
        }
        <hr class='hr'>
        <table style="width:40%">
            <tr>
                <th class="navy-text">Gesamt FA#. :</th>
                <th class="black-text blue-cell">@FormatHelper.FormatDecimal(Model.Header.Total, 2)</th>
            </tr>
        </table>
    }
	<pre></pre>
</body>
</html>