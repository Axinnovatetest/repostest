@model Infrastructure.Services.Reporting.Models.CTS.BacklogFGReportModel
@using Infrastructure.Services.Helpers
<html>
<head>
    <style>
         @@page {
            margin-top: 20;
            margin-bottom: 80;
            margin-left: 20;
            margin-right: 50;
            font-family: Helvetica, sans-serif;
        }

        body {
            font-family: Helvetica, sans-serif;
        }

        table {
            border-collapse: collapse;
        }
        td, tr {
            padding: 10px 10px 0 0;
        }
        td {
            font-size: 10px !important;
        }
        .header-cell{
            color:#000080;
            font-size:10px;
        }
        .header-cell-hidden{
            color:#000080;
            font-size:10px;
            color:transparent;
            padding:2px !important;
        }
        .detail-cell{
            color:black;
            font-size:10px;
            border:0.5px solid black !important;
            padding:2px !important;
        }
        .adress-cell{
            color:green;
            font-weight:bold;
        }
        .nobr {
            white-space: nowrap;
        }
        .over-table
        {
            padding:2px;
            border:0.5px solid #000080;
            font-size:10px;
            text-align:center;
        }
        .det-cell {
            border:0.5px solid black !important;
            text-align:center !important;
            padding:2px !important
        }
        .no-br{
            white-space: nowrap;
        }
        hr {
            border: none;
            border-top: 2px solid #000080;
            padding: 5px;
        }
        .sum-cell {
            font-weight: bold !important;
            font-size: 10px !important;
            color:black !important;
        }
        .sum-cell-all {
            font-weight: bold !important;
            font-size: 15px !important;
            color:black !important;
        }
          </style>
    </head>
    <body style="font-size:14px;">
        @if(Model is not null && Model.Header is not null && Model.Header.Count()>0)
        {
            var lager=Model.Details.Select(d=>d.PRORT).Distinct().ToList();

            <p style="font-weight:bold;margin-left:10px">Back Log - PSZ          Vom @Model.Details[0].Ausdr2  -  @Model.Details[0].Ausdr1    @(String.Join("-",lager))</p>
            <hr>
            foreach(var header in Model.Header)
            {
               var details= Model.Details.Where(d=>d.PRORT==header.PRORT).ToList();
               var totalGesamt=details.Sum(d=>d.Gesamtpreis);
               var totalGesamtPersonal=details.Sum(d=>d.GesamtpersonalkostenValue);
               var totalGesamtKosten=details.Sum(d=>d.GesamtkostenValue);
               var totalBDI=(totalGesamt - totalGesamtKosten);
               var totalPercent=(totalGesamt-totalGesamtKosten)/totalGesamtKosten*100;

               <table style="width: 100%;font-size:10px;">
                   <tr>
                       <td class="header-cell no-br" style="color:orange !important;font-size:12px !important">@details[0].PRORT</td>
                       <td class="header-cell-hidden no-br">AB Dok.-Nr</td>
                       <td class="header-cell-hidden no-br">AB</td>
                       <td class="header-cell-hidden no-br">#PSZ</td>
                       <td class="header-cell-hidden no-br">Bezeichnug</td>
                       <td class="header-cell-hidden no-br">Anzahl Bestellit</td>
                       <td class="header-cell-hidden no-br">Anzahl Offen</td>
                       <td class="header-cell-hidden no-br">#FA</td>
                       <td class="header-cell-hidden no-br">Termin</td>
                       <td class="header-cell over-table" colspan="2">Umsatz</td>
                       <td class="header-cell over-table" colspan="4">Kosten</td>
                       @if(Model.IsAdmin){
                       <td class="header-cell-hidden no-br">DB I</td>
                       <td class="header-cell-hidden no-br">%</td>
                       }
                   </tr>
                   <tr>
                       <td class="header-cell no-br">Kunde</td>
                       <td class="header-cell no-br">AB Dok.-Nr</td>
                       <td class="header-cell no-br">AB</td>
                       <td class="header-cell no-br">#PSZ</td>
                       <td class="header-cell no-br">Bezeichnug</td>
                       <td class="header-cell">Anzahl Bestellit</td>
                       <td class="header-cell">Anzahl Offen</td>
                       <td class="header-cell no-br">#FA</td>
                       <td class="header-cell no-br">Termin</td>
                       <td class="header-cell no-br">Einzel</td>
                       <td class="header-cell no-br">Gesamt</td>
                       <td class="header-cell">Mat + Zeit Einzel</td>
                       <td class="header-cell">Zeit Einzeln</td>
                       <td class="header-cell">Zeit Gesamt</td>
                       <td class="header-cell">Mat + Zeit Gesamt</td>
                       @if(Model.IsAdmin){
                       <td class="header-cell no-br">DB I</td>
                       <td class="header-cell no-br">%</td>
                       }
                   </tr>
                   <tbody>
                       @foreach(var detail in details){
                            var einzel=detail.Einzelpreis/detail.Preiseinheit;
                            var dbi=(detail.Gesamtpreis-detail.GesamtkostenValue).ToString("F2");

                           <tr>
                               <td class="det-cell no-br">@detail.Name1</td>
                               <td class="det-cell">@detail.DOC_Number</td>
                               <td class="det-cell no-br">@detail.Angebot_Nr</td>
                               <td class="det-cell no-br">@detail.Artikelnummer</td>
                               <td class="det-cell">@detail.Bezeichnung1</td>
                               <td class="det-cell no-br">@detail.OriginalAnzahl</td>
                               <td class="det-cell no-br">@detail.Anzahl</td>
                               <td class="det-cell no-br">@detail.Fertigungsnummer</td>
                               <td class="det-cell no-br">@detail.Liefertermin</td>
                               <td class="det-cell no-br">@einzel €</td>
                               <td class="det-cell no-br">@detail.Gesamtpreis €</td>
                               <td class="det-cell no-br">@detail.Kosten €</td>
                               <td class="det-cell no-br">@detail.Betrag €</td>
                               <td class="det-cell no-br">@detail.Gesamtpersonalkosten €</td>
                               <td class="det-cell no-br">@detail.Gesamtkosten €</td>
                               @if(Model.IsAdmin){
                               <td class="det-cell no-br">@dbi €</td>
                               <td class="det-cell no-br">@detail.Percent.ToString("F1") %</td>
                               }
                           </tr>
                       }
                   </tbody>
               </table>
               @if(Model.IsAdmin){
                   <table style="width: 100%;font-size:10px;">
                   <tr>
                       <td class="header-cell-hidden no-br">Kunde</td>
                       <td class="header-cell-hidden no-br">AB Dok.-Nr</td>
                       <td class="header-cell-hidden no-br">AB</td>
                       <td class="header-cell-hidden no-br">#PSZ</td>
                       <td class="header-cell-hidden no-br">Bezeichnug</td>
                       <td class="header-cell-hidden no-br">Anzahl Bestellit</td>
                       <td class="header-cell-hidden no-br">Anzahl Offen</td>
                       <td class="header-cell-hidden no-br">#FA</td>
                       <td class="header-cell-hidden no-br">Termin</td>
                       <td class="header-cell-hidden no-br">Einzel</td>
                       <td class="header-cell sum-cell" colspan="2">@FormatHelper.FormatDecimal(totalGesamt,2) €</td>
                       <td class="header-cell sum-cell" colspan="2">@FormatHelper.FormatDecimal(totalGesamtPersonal,2) €</td>
                       <td class="header-cell sum-cell" colspan="2">@FormatHelper.FormatDecimal(totalGesamtKosten,2) €</td>
                       <td class="header-cell sum-cell" colspan="2">@FormatHelper.FormatDecimal(totalBDI,2) €</td>
                       <td class="header-cell sum-cell" colspan="2">@FormatHelper.FormatDecimal2Places(totalPercent) %</td>                     
                   </tr>
               </table>
               }
                <br/><br/>
            }
            <hr>
             var allTotalGesamt=Model.Details.Sum(h=>h.Gesamtpreis);
             var alltotalGesamtPersonal=Model.Details.Sum(h=>h.GesamtpersonalkostenValue);
             var alltotalGesamtKosten=Model.Details.Sum(h=>h.GesamtkostenValue);
             var alltotalBDI=(allTotalGesamt - alltotalGesamtKosten);
             var alltotalPercent=(allTotalGesamt-alltotalGesamtKosten)/alltotalGesamtKosten*100;
            <table style="width: 100%;font-size:10px;">
                   <tr>
                       <td class="header-cell-hidden no-br">Kunde</td>
                       <td class="header-cell-hidden no-br">AB Dok.-Nr</td>
                       <td class="header-cell-hidden no-br">AB</td>
                       <td class="header-cell-hidden no-br">#PSZ</td>
                       <td class="header-cell-hidden no-br">Bezeichnug</td>
                       <td class="header-cell-hidden no-br">Anzahl Bestellit</td>
                       <td class="header-cell-hidden no-br">Anzahl Offen</td>
                       <td class="header-cell-hidden no-br">#FA</td>
                       <td class="header-cell-hidden no-br">Termin</td>
                       <td class="header-cell-hidden no-br">Einzel</td>
                       <td class="header-cell sum-cell-all" colspan="2">@FormatHelper.FormatDecimal(allTotalGesamt,2) €</td>
                       <td class="header-cell sum-cell-all" colspan="2">@FormatHelper.FormatDecimal(alltotalGesamtPersonal,2) €</td>
                       <td class="header-cell sum-cell-all" colspan="2">@FormatHelper.FormatDecimal(alltotalGesamtKosten,2) €</td>
                       @if(Model.IsAdmin){
                       <td class="header-cell sum-cell-all" colspan="2">@FormatHelper.FormatDecimal(alltotalBDI,2) €</td>
                       <td class="header-cell sum-cell-all" colspan="2">@FormatHelper.FormatDecimal2Places(alltotalPercent) %</td>
                       }
                   </tr>
               </table>
        }
    </body>
     <pre></pre>
</html>